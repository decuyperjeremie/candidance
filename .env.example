# Tatiana — environment configuration
# Copy this file to `.env` (git-ignored) and fill in values as needed.
#
# Local install (PC de Tatiana, via setup/install.md): the defaults below work
# as-is — NOTHING needs editing. Generation uses the Claude account logged in
# locally (LLM_PROVIDER=claude-code). Everything else is optional.
#
# Profile loading and the smoke check's profile step work WITHOUT any of these.
# An LLM completion only needs the settings for the provider you select.

# Which LLM backend to use:
#   claude-code (default) -> local `claude` CLI, uses your Claude Code / Max
#                            subscription (no API key, no per-token bill within
#                            your plan's included credits). Requires the CLI
#                            installed and logged in: `claude` then /login.
#   ollama                -> a local model (free, offline, lower quality).
#   claude                -> the paid Anthropic API (per-token billing, needs a key).
LLM_PROVIDER=claude-code

# --- claude-code (Claude Code CLI / subscription) ---
# Path to the claude binary (override if it's not on PATH).
CLAUDE_CLI_PATH=claude
# Model: an alias like "sonnet"/"opus" (resolves to the latest) or a full id.
CLAUDE_CODE_MODEL=sonnet

# --- Ollama (local) ---
# Used when LLM_PROVIDER=ollama. Requires a running Ollama server
# (https://ollama.com) with the model pulled: `ollama pull llama3.1`.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- claude (paid Anthropic API) ---
# Only needed if LLM_PROVIDER=claude. Create a key at https://console.anthropic.com/ .
# This is billed separately from your Max subscription.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# =====================================================================
# Job sources (Slice 2 — job-discovery)
# =====================================================================

# Which connectors run during a discovery pass (comma-separated).
# Default (unset) = france-travail only. Known names:
#   france-travail              -> public API, free, reliable (recommended).
#   apec, welcome-to-the-jungle -> scraping, opt-in, non-blocking.
#   linkedin, indeed, glassdoor -> best-effort, need the optional `playwright`
#                                  dependency + `npx playwright install chromium`.
#   company-site                -> crawl direct career pages; configure
#                                  COMPANY_CAREER_SITES (see below).
# JOB_SOURCES=france-travail,apec,welcome-to-the-jungle

# --- Crawl backend (best-effort connectors: linkedin, indeed, glassdoor, company-site) ---
# Default backend: headless Chromium via the optional playwright dep.
#   npm i playwright && npx playwright install chromium
# Alternative backends (pluggable seam — set via code in lib/sources/crawl-backend.ts):
#   Firecrawl: https://www.firecrawl.dev/
#   Obscura:   https://github.com/h4ckf0r0day/obscura
# No env var needed for Playwright; switching backends requires a small code change.

# --- company-site connector ---
# Comma-separated list of direct company career page URLs to crawl.
# Only needed if JOB_SOURCES includes company-site.
# COMPANY_CAREER_SITES=https://careers.acme.fr,https://jobs.example.com/fr

# --- France Travail (ex-Pôle Emploi) "Offres d'emploi v2" API --- (OPTIONAL)
# Free, and only needed to fetch real job offers. Leave commented to skip:
# discovery then degrades gracefully to 0 offers instead of failing.
# Create a developer account + app at https://francetravail.io , then subscribe
# the app to the "Offres d'emploi v2" API. "Identifiant" = client id,
# "Clé secrète" = client secret. Uncomment and fill to enable:
# FRANCE_TRAVAIL_CLIENT_ID=
# FRANCE_TRAVAIL_CLIENT_SECRET=
